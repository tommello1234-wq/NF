# Servidor
PORT=3001
NODE_ENV=development

# Supabase DEDICADO do produto NFe (NÃO é o mesmo da ótica!)
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# Criptografia dos certificados digitais (AES-256-GCM)
# Gerar com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CERT_ENCRYPTION_KEY=troque_por_uma_chave_hex_de_64_caracteres

# Admin auth (painel admin usa Supabase Auth no próprio projeto)
# Frontend passa Authorization: Bearer <jwt do Supabase>

# NFe
NFE_AMBIENTE=2   # 1=produção, 2=homologação
NFE_UF=CE
